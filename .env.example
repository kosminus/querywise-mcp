# --- querywise-mcp configuration (all optional; sane defaults provided) ---

# Where the SQLite metadata store lives (default: ~/.querywise/querywise.db)
# QUERYWISE_HOME=~/.querywise
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/querywise.db

# Encrypt stored target-DB connection strings (CHANGE THIS in production)
ENCRYPTION_KEY=dev-encryption-key-change-in-production

# --- LLM provider (only needed for `ask` / `generate_sql` and cloud embeddings) ---
# Anthropic (default)
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=...
# OPENAI_API_KEY=...                 # OpenAI is used for embeddings under Anthropic
EMBEDDING_DIMENSION=1536

# --- Fully local (no API keys) via Ollama ---
# DEFAULT_LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSION=768

# --- MCP transport (when running `querywise serve`) ---
MCP_TRANSPORT=stdio                   # stdio | http
MCP_HOST=127.0.0.1
MCP_PORT=8077

# --- Sample DB (used by `querywise seed-sample`) ---
# Defaults to a zero-infra local SQLite file built at ~/.querywise/sample_ifrs9.db.
# SAMPLE_DB_CONNECTOR_TYPE=sqlite
# To point the sample at your own Postgres instead, set both:
# SAMPLE_DB_CONNECTOR_TYPE=postgresql
# SAMPLE_DB_CONNECTION_STRING=postgresql://sample:sample_dev@localhost:5433/sampledb
